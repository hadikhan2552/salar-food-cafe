rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. GLOBAL HELPERS
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "h1ammad1o1@gmail.com"
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // 2. ENTITY VALIDATORS
    // -------------------------------------------------------------------------
    function isValidMenuItem(data) {
      return data.title is string && data.title.size() > 0 &&
             data.price is number && data.price >= 0;
    }

    function isValidReview(data) {
      return data.user is string && data.user.size() > 0 &&
             data.comment is string && data.comment.size() > 0 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidOrder(data) {
      return data.name is string && data.name.size() > 0 &&
             data.contact is string &&
             data.items is list && data.items.size() > 0 &&
             data.total is number;
    }

    function isValidDeal(data) {
      return data.title is string && data.title.size() > 0 &&
             data.items is list && data.items.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.originalPrice is number &&
             data.discount is number;
    }

    // -------------------------------------------------------------------------
    // 3. ACCESS CONTROL RULES
    // -------------------------------------------------------------------------

    // Public Collections (Read-Only for Guest)
    match /menu/{dishId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /deals/{dealId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if true; // Allow guests to post pending reviews
      allow update, delete: if isAdmin();
    }

    // Admin Collection
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
